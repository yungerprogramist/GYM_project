{
  "openapi": "3.0.3",
  "info": {
    "title": "Fitness Tracker API",
    "version": "1.0.0",
    "description": "API для фитнес-трекера с календарем тренировок и статистикой"
  },
  "servers": [
    {
      "url": "/",
      "description": "Сервер API"
    }
  ],
  "tags": [
    { "name": "Calendar", "description": "Календарь тренировок" },
    { "name": "Statistics", "description": "Статистика тренировок" },
    { "name": "RecentExercises", "description": "Недавние упражнения" },
    { "name": "Workouts", "description": "Тренировки" }
  ],
  "paths": {
    "/api/calendar/month/{year}/{month}/": {
      "get": {
        "summary": "Получить календарь тренировок за месяц",
        "description": "Возвращает данные о тренировках за указанный месяц для авторизованного пользователя",
        "tags": ["Calendar"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "year",
            "in": "path",
            "required": true,
            "description": "Год (например, 2026)",
            "schema": {
              "type": "integer",
              "minimum": 2000,
              "maximum": 2100,
              "example": 2026
            }
          },
          {
            "name": "month",
            "in": "path",
            "required": true,
            "description": "Месяц (1-12)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 12,
              "example": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/WorkoutCalendarItem" }
                  },
                  "example": {
                    "2026-05-15": [
                      { "id": 1, "date": "2026-05-15", "exercise_count": 5, "total_weight": 750.5 }
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "description": "Неверный формат года или месяца"
          },
          "401": {
            "description": "Не авторизован"
          }
        }
      }
    },
    "/api/statistics/summary/": {
      "get": {
        "summary": "Получить сводную статистику",
        "description": "Возвращает общую статистику тренировок пользователя",
        "tags": ["Statistics"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatisticsSummary" }
              }
            }
          },
          "401": {
            "description": "Не авторизован"
          }
        }
      }
    },
    "/api/statistics/period/": {
      "get": {
        "summary": "Получить статистику за период",
        "description": "Возвращает статистику тренировок за указанный период",
        "tags": ["Statistics"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "required": true,
            "description": "Начальная дата периода",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-05-01"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "required": true,
            "description": "Конечная дата периода",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-05-31"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatisticsPeriod" }
              }
            }
          },
          "400": {
            "description": "Неверный формат даты или период указан некорректно"
          },
          "401": {
            "description": "Не авторизован"
          }
        }
      }
    },
    "/api/exercises/recent/": {
      "get": {
        "summary": "Получить список недавних упражнений",
        "description": "Возвращает список недавно использованных упражнений для авторизованного пользователя",
        "tags": ["RecentExercises"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/RecentExercise" }
                }
              }
            }
          },
          "401": {
            "description": "Не авторизован"
          }
        }
      }
    },
    "/api/exercises/recent/update/": {
      "post": {
        "summary": "Обновить счетчик недавних упражнений",
        "description": "Обновляет информацию об использовании упражнения (увеличивает счетчик и обновляет дату)",
        "tags": ["RecentExercises"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "exercise_id": {
                    "type": "integer",
                    "description": "ID упражнения",
                    "example": 42
                  }
                },
                "required": ["exercise_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешно обновлено",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecentExercise" }
              }
            }
          },
          "400": {
            "description": "Не указан exercise_id или упражнение не найдено"
          },
          "401": {
            "description": "Не авторизован"
          },
          "404": {
            "description": "Упражнение не найдено"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT токен для авторизации"
      }
    },
    "schemas": {
      "Workout": {
        "type": "object",
        "description": "Модель тренировки",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true,
            "description": "Уникальный идентификатор тренировки",
            "example": 1
          },
          "user": {
            "type": "integer",
            "readOnly": true,
            "description": "ID пользователя",
            "example": 5
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Дата тренировки",
            "example": "2026-05-21"
          },
          "notes": {
            "type": "string",
            "description": "Заметки к тренировке",
            "nullable": true,
            "example": "Хорошая тренировка, прогресс в жиме лежа"
          }
        },
        "required": ["user", "date"]
      },
      "WorkoutCalendarItem": {
        "type": "object",
        "description": "Элемент календаря тренировок",
        "properties": {
          "id": {
            "type": "integer",
            "description": "ID тренировки",
            "example": 1
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Дата тренировки",
            "example": "2026-05-15"
          },
          "exercise_count": {
            "type": "integer",
            "description": "Количество упражнений в тренировке",
            "example": 5
          },
          "total_weight": {
            "type": "number",
            "format": "float",
            "description": "Общий поднятый вес",
            "example": 750.5
          }
        }
      },
      "StatisticsSummary": {
        "type": "object",
        "description": "Сводная статистика",
        "properties": {
          "total_workouts": {
            "type": "integer",
            "description": "Общее количество тренировок",
            "example": 45
          },
          "total_exercises": {
            "type": "integer",
            "description": "Общее количество выполненных упражнений",
            "example": 234
          },
          "total_sets": {
            "type": "integer",
            "description": "Общее количество подходов",
            "example": 1250
          },
          "total_weight": {
            "type": "number",
            "format": "float",
            "description": "Общий поднятый вес за все время",
            "example": 87500.5
          },
          "avg_workouts_per_week": {
            "type": "number",
            "format": "float",
            "description": "Среднее количество тренировок в неделю",
            "example": 3.5
          },
          "longest_streak": {
            "type": "integer",
            "description": "Самая длинная серия тренировок подряд (дней)",
            "example": 12
          },
          "current_streak": {
            "type": "integer",
            "description": "Текущая серия тренировок подряд (дней)",
            "example": 5
          },
          "most_active_month": {
            "type": "string",
            "description": "Самый активный месяц",
            "example": "2026-03"
          },
          "most_common_exercise": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        }
      },
      "StatisticsPeriod": {
        "type": "object",
        "description": "Статистика за период",
        "properties": {
          "period": {
            "type": "object",
            "properties": {
              "start_date": {
                "type": "string",
                "format": "date",
                "example": "2026-05-01"
              },
              "end_date": {
                "type": "string",
                "format": "date",
                "example": "2026-05-31"
              }
            }
          },
          "total_workouts": {
            "type": "integer",
            "description": "Количество тренировок за период",
            "example": 12
          },
          "total_exercises": {
            "type": "integer",
            "description": "Количество упражнений за период",
            "example": 67
          },
          "total_sets": {
            "type": "integer",
            "description": "Количество подходов за период",
            "example": 380
          },
          "total_weight": {
            "type": "number",
            "format": "float",
            "description": "Общий поднятый вес за период",
            "example": 27500.0
          },
          "workouts_per_day": {
            "type": "array",
            "description": "Тренировки по дням",
            "items": {
              "type": "object",
              "properties": {
                "date": { "type": "string", "format": "date" },
                "workouts_count": { "type": "integer" },
                "total_weight": { "type": "number" }
              }
            }
          },
          "trend": {
            "type": "string",
            "description": "Тренд активности (increasing, decreasing, stable)",
            "enum": ["increasing", "decreasing", "stable"],
            "example": "increasing"
          }
        }
      },
      "RecentExercise": {
        "type": "object",
        "description": "Модель недавних упражнений",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true,
            "description": "Уникальный идентификатор записи",
            "example": 1
          },
          "exercise_id": {
            "type": "integer",
            "readOnly": true,
            "description": "ID упражнения",
            "example": 42
          },
          "exercise_name": {
            "type": "string",
            "readOnly": true,
            "description": "Название упражнения",
            "example": "Жим лежа"
          },
          "last_used": {
            "type": "string",
            "format": "date-time",
            "readOnly": true,
            "description": "Дата и время последнего использования",
            "example": "2026-05-21T15:30:00Z"
          },
          "use_count": {
            "type": "integer",
            "readOnly": true,
            "description": "Количество использований",
            "minimum": 0,
            "example": 15
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}