{
  "openapi": "3.0.3",
  "info": {
    "title": "Exercises API",
    "version": "1.0.0",
    "description": "API для управления упражнениями и группами мышц"
  },
  "servers": [
    {
      "url": "/api/v1/exercises"
    }
  ],
  "paths": {
    "/muscle-groups/": {
      "get": {
        "summary": "Список всех групп мышц",
        "tags": ["MuscleGroups"],
        "security": [],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MuscleGroup"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/muscle-groups/{id}/": {
      "get": {
        "summary": "Детали группы мышц",
        "tags": ["MuscleGroups"],
        "security": [],
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MuscleGroup" }
              }
            }
          },
          "404": { "description": "Не найдено" }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Список упражнений",
        "tags": ["Exercises"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "muscle_group",
            "in": "query",
            "description": "Фильтр по ID группы мышц",
            "schema": { "type": "integer" }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Поиск по названию и описанию",
            "schema": { "type": "string" }
          },
          {
            "name": "ordering",
            "in": "query",
            "description": "Сортировка (name, id, -name, -id)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Exercise" }
                }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      },
      "post": {
        "summary": "Создать упражнение (только admin)",
        "tags": ["Exercises"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/ExerciseWrite" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Создано",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exercise" }
              }
            }
          },
          "400": { "description": "Ошибка валидации" },
          "403": { "description": "Нет прав (не admin)" }
        }
      }
    },
    "/{id}/": {
      "get": {
        "summary": "Детали упражнения",
        "tags": ["Exercises"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exercise" }
              }
            }
          },
          "401": { "description": "Не авторизован" },
          "404": { "description": "Не найдено" }
        }
      },
      "put": {
        "summary": "Обновить упражнение (только admin)",
        "tags": ["Exercises"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/ExerciseWrite" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновлено",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exercise" }
              }
            }
          },
          "400": { "description": "Ошибка валидации" },
          "403": { "description": "Нет прав" },
          "404": { "description": "Не найдено" }
        }
      },
      "patch": {
        "summary": "Частичное обновление упражнения (только admin)",
        "tags": ["Exercises"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/ExerciseWrite" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновлено",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exercise" }
              }
            }
          },
          "403": { "description": "Нет прав" },
          "404": { "description": "Не найдено" }
        }
      },
      "delete": {
        "summary": "Удалить упражнение (только admin)",
        "tags": ["Exercises"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "204": { "description": "Удалено" },
          "403": { "description": "Нет прав" },
          "404": { "description": "Не найдено" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      }
    },
    "schemas": {
      "MuscleGroup": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "maxLength": 100
          }
        },
        "required": ["name"]
      },
      "Exercise": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "readOnly": true
          },
          "muscle_group": {
            "type": "integer",
            "description": "ID группы мышц"
          },
          "muscle_group_name": {
            "type": "string",
            "readOnly": true,
            "description": "Название группы мышц"
          },
          "name": {
            "type": "string",
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "default": ""
          },
          "image": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "readOnly": true
          }
        }
      },
      "ExerciseWrite": {
        "type": "object",
        "properties": {
          "muscle_group": {
            "type": "integer",
            "description": "ID группы мышц"
          },
          "name": {
            "type": "string",
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "default": ""
          },
          "image": {
            "type": "string",
            "format": "binary",
            "nullable": true
          }
        },
        "required": ["muscle_group", "name"]
      }
    }
  }
}