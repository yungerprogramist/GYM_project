{
  "openapi": "3.0.3",
  "info": {
    "title": "Gym Project API",
    "version": "1.0.0",
    "description": "API для фитнес-трекера"
  },
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "tags": [
    { "name": "MuscleGroups", "description": "Группы мышц" },
    { "name": "Exercises", "description": "Каталог упражнений" },
    { "name": "Workouts", "description": "Дневник тренировок" },
    { "name": "Sets", "description": "Подходы" },
    { "name": "Notes", "description": "Заметки пользователя" },
    { "name": "Users", "description": "Профиль и настройки пользователя" }
  ],
  "paths": {
    "/exercises/muscle-groups/": {
      "get": {
        "summary": "Список всех групп мышц",
        "tags": ["MuscleGroups"],
        "security": [],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/MuscleGroup" }
                }
              }
            }
          }
        }
      }
    },
    "/exercises/muscle-groups/{id}/": {
      "get": {
        "summary": "Детали группы мышц",
        "tags": ["MuscleGroups"],
        "security": [],
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MuscleGroup" }
              }
            }
          },
          "404": { "description": "Не найдено" }
        }
      }
    },
    "/exercises/": {
      "get": {
        "summary": "Список упражнений",
        "tags": ["Exercises"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "muscle_group",
            "in": "query",
            "description": "Фильтр по ID группы мышц",
            "schema": { "type": "integer" }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Поиск по названию и описанию",
            "schema": { "type": "string" }
          },
          {
            "name": "ordering",
            "in": "query",
            "description": "Сортировка (name, id, -name, -id)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Exercise" }
                }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      },
      "post": {
        "summary": "Создать упражнение (только admin)",
        "tags": ["Exercises"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ExerciseWrite" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Создано",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exercise" }
              }
            }
          },
          "400": { "description": "Ошибка валидации" },
          "403": { "description": "Нет прав (не admin)" }
        }
      }
    },
    "/exercises/{id}/": {
      "get": {
        "summary": "Детали упражнения",
        "tags": ["Exercises"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exercise" }
              }
            }
          },
          "401": { "description": "Не авторизован" },
          "404": { "description": "Не найдено" }
        }
      },
      "put": {
        "summary": "Обновить упражнение (только admin)",
        "tags": ["Exercises"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ExerciseWrite" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновлено",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exercise" }
              }
            }
          },
          "400": { "description": "Ошибка валидации" },
          "403": { "description": "Нет прав" },
          "404": { "description": "Не найдено" }
        }
      },
      "delete": {
        "summary": "Удалить упражнение (только admin)",
        "tags": ["Exercises"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "204": { "description": "Удалено" },
          "403": { "description": "Нет прав" },
          "404": { "description": "Не найдено" }
        }
      }
    },
    "/workouts/": {
      "get": {
        "summary": "Список тренировок",
        "tags": ["Workouts"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/WorkoutListItem" }
                }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/workouts/{workout_id}/": {
      "get": {
        "summary": "Детали тренировки",
        "tags": ["Workouts"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/workout_id" }
        ],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Workout" }
              }
            }
          },
          "404": { "description": "Не найдена или чужая" }
        }
      },
      "delete": {
        "summary": "Удалить тренировку",
        "tags": ["Workouts"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/workout_id" }
        ],
        "responses": {
          "204": { "description": "Удалено" },
          "404": { "description": "Не найдена или чужая" }
        }
      }
    },
    "/workouts/today/": {
      "get": {
        "summary": "Сегодняшняя тренировка (автосоздание)",
        "tags": ["Workouts"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Workout" }
              }
            }
          }
        }
      }
    },
    "/workouts/date/{date}/": {
      "get": {
        "summary": "Тренировка по дате",
        "tags": ["Workouts"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "date" },
            "example": "2026-05-21"
          }
        ],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Workout" }
              }
            }
          },
          "400": { "description": "Неверный формат даты" },
          "404": { "description": "Тренировка не найдена" }
        }
      }
    },
    "/workouts/{workout_id}/stats/": {
      "get": {
        "summary": "Статистика тренировки",
        "tags": ["Workouts"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/workout_id" }
        ],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkoutStats" }
              }
            }
          }
        }
      }
    },
    "/workouts/{workout_id}/exercises/": {
      "post": {
        "summary": "Добавить упражнение в тренировку",
        "tags": ["Workouts"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/workout_id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "exercise_id": { "type": "integer", "example": 1 },
                  "exercise_order": { "type": "integer", "example": 1 }
                },
                "required": ["exercise_id"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Добавлено",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkoutExercise" }
              }
            }
          },
          "409": { "description": "Уже в тренировке" }
        }
      }
    },
    "/workouts/{workout_id}/exercises/{exercise_id}/": {
      "delete": {
        "summary": "Удалить упражнение из тренировки",
        "tags": ["Workouts"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/workout_id" },
          { "$ref": "#/components/parameters/exercise_id" }
        ],
        "responses": {
          "204": { "description": "Удалено" }
        }
      }
    },
    "/workouts/{workout_id}/exercises/{exercise_id}/sets/": {
      "post": {
        "summary": "Добавить подход",
        "tags": ["Sets"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/workout_id" },
          { "$ref": "#/components/parameters/exercise_id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "weight": { "type": "number", "example": 80 },
                  "reps": { "type": "integer", "example": 10 },
                  "set_number": { "type": "integer", "example": 1 }
                },
                "required": ["weight", "reps"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Создано",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Set" }
              }
            }
          },
          "400": { "description": "Вес ≤ 0 или повторения ≤ 0" }
        }
      }
    },
    "/sets/{set_id}/": {
      "put": {
        "summary": "Обновить подход",
        "tags": ["Sets"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/set_id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "weight": { "type": "number" },
                  "reps": { "type": "integer" },
                  "set_number": { "type": "integer" }
                },
                "required": ["weight", "reps", "set_number"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновлено",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Set" }
              }
            }
          },
          "404": { "description": "Не найден или чужой" }
        }
      },
      "delete": {
        "summary": "Удалить подход",
        "tags": ["Sets"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/set_id" }
        ],
        "responses": {
          "204": { "description": "Удалено" },
          "404": { "description": "Не найден или чужой" }
        }
      }
    },
    "/notes/": {
      "get": {
        "summary": "Получить заметку (автосоздание если нет)",
        "tags": ["Notes"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Note" }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/notes/{id}/": {
      "put": {
        "summary": "Обновить заметку",
        "tags": ["Notes"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NoteWrite" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновлено",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Note" }
              }
            }
          },
          "400": { "description": "Ошибка валидации" },
          "401": { "description": "Не авторизован" }
        }
      },
      "delete": {
        "summary": "Удалить заметку",
        "tags": ["Notes"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/id" }
        ],
        "responses": {
          "204": { "description": "Удалено" },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/users/register/": {
      "post": {
        "summary": "Регистрация",
        "tags": ["Users"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserRegister" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "400": { "description": "Ошибка валидации" }
        }
      }
    },
    "/users/login/": {
      "post": {
        "summary": "Вход",
        "tags": ["Users"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserLogin" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "401": { "description": "Неверный логин или пароль" }
        }
      }
    },
    "/users/logout/": {
      "post": {
        "summary": "Выход",
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refresh": { "type": "string" }
                },
                "required": ["refresh"]
              }
            }
          }
        },
        "responses": {
          "205": { "description": "Успешный выход" },
          "400": { "description": "Невалидный токен" }
        }
      }
    },
    "/users/profile/": {
      "get": {
        "summary": "Профиль пользователя",
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserProfile" }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      },
      "patch": {
        "summary": "Обновить профиль",
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserProfile" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновлено",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserProfile" }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      }
    },
    "/users/settings/": {
      "get": {
        "summary": "Настройки пользователя",
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserSettings" }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      },
      "patch": {
        "summary": "Обновить настройки",
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserSettings" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновлено",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserSettings" }
              }
            }
          },
          "401": { "description": "Не авторизован" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "workout_id": {
        "name": "workout_id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "exercise_id": {
        "name": "exercise_id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "set_id": {
        "name": "set_id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      }
    },
    "schemas": {
      "MuscleGroup": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "readOnly": true },
          "name": { "type": "string", "maxLength": 100 }
        },
        "required": ["name"]
      },
      "Exercise": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "readOnly": true },
          "muscle_group": { "type": "integer", "description": "ID группы мышц" },
          "muscle_group_name": { "type": "string", "readOnly": true },
          "name": { "type": "string", "maxLength": 200 },
          "description": { "type": "string", "default": "" },
          "image": { "type": "string", "format": "uri", "nullable": true, "readOnly": true }
        }
      },
      "ExerciseWrite": {
        "type": "object",
        "properties": {
          "muscle_group": { "type": "integer", "description": "ID группы мышц" },
          "name": { "type": "string", "maxLength": 200 },
          "description": { "type": "string", "default": "" },
          "image": { "type": "string", "format": "binary", "nullable": true }
        },
        "required": ["muscle_group", "name"]
      },
      "WorkoutListItem": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "readOnly": true },
          "date": { "type": "string", "format": "date" },
          "exercise_count": { "type": "integer" }
        }
      },
      "Workout": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "readOnly": true },
          "date": { "type": "string", "format": "date" },
          "exercises": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/WorkoutExercise" }
          },
          "exercise_count": { "type": "integer" },
          "set_count": { "type": "integer" },
          "total_weight": { "type": "number" }
        }
      },
      "WorkoutExercise": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "readOnly": true },
          "exercise_id": { "type": "integer", "writeOnly": true },
          "exercise_name": { "type": "string", "readOnly": true },
          "muscle_group": { "type": "string", "readOnly": true },
          "exercise_order": { "type": "integer" },
          "sets": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Set" }
          }
        }
      },
      "Set": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "readOnly": true },
          "weight": { "type": "number", "example": 80 },
          "reps": { "type": "integer", "example": 10 },
          "set_number": { "type": "integer", "example": 1 }
        }
      },
      "WorkoutStats": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "exercise_count": { "type": "integer" },
          "set_count": { "type": "integer" },
          "total_weight": { "type": "number" }
        }
      },
      "Note": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "readOnly": true },
          "content": { "type": "string" },
          "updated_at": { "type": "string", "format": "date-time", "readOnly": true }
        }
      },
      "NoteWrite": {
        "type": "object",
        "properties": {
          "content": { "type": "string" }
        },
        "required": ["content"]
      },
      "UserRegister": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "writeOnly": true, "minLength": 6 }
        },
        "required": ["username", "password"]
      },
      "UserLogin": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "password": { "type": "string", "writeOnly": true }
        },
        "required": ["username", "password"]
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "user": { "$ref": "#/components/schemas/UserFull" },
          "tokens": {
            "type": "object",
            "properties": {
              "access": { "type": "string" },
              "refresh": { "type": "string" }
