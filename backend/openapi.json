{
  "openapi": "3.0.3",
  "info": {
    "title": "Gym Project API",
    "version": "1.0.0",
    "description": "API для фитнес-трекера с календарем тренировок, статистикой и дневником тренировок"
  },
  "servers": [
    {
      "url": "/",
      "description": "Основной сервер API"
    }
  ],
  "tags": [
    { "name": "MuscleGroups", "description": "Группы мышц" },
    { "name": "Exercises", "description": "Каталог упражнений" },
    { "name": "Workouts", "description": "Дневник тренировок" },
    { "name": "Sets", "description": "Подходы" },
    { "name": "Notes", "description": "Заметки пользователя" },
    { "name": "Users", "description": "Профиль и настройки пользователя" },
    { "name": "Programs", "description": "Программы тренировок" },
    { "name": "Calendar", "description": "Календарь тренировок" },
    { "name": "Statistics", "description": "Статистика тренировок" },
    { "name": "RecentExercises", "description": "Недавние упражнения" },
    { "name": "Measurements", "description": "Измерения веса" }
  ],
  "paths": {
    "/api/v1/measurements/weight/": {
      "get": {
        "summary": "Список записей веса",
        "tags": ["Measurements"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/ordering" },
          { "$ref": "#/components/parameters/page" },
          {
            "name": "period",
            "in": "query",
            "description": "Фильтр по периоду: week, month, quarter, year, custom",
            "schema": { "type": "string", "enum": ["week", "month", "quarter", "year", "custom"] }
          },
          {
            "name": "date_from",
            "in": "query",
            "description": "Начальная дата (для period=custom)",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "date_to",
            "in": "query",
            "description": "Конечная дата (для period=custom)",
            "schema": { "type": "string", "format": "date" }
          }
        ],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaginatedWeightRecordList" }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Добавить запись веса",
        "tags": ["Measurements"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WeightRecordWrite" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Создано",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WeightRecord" }
              }
            }
          },
          "400": { "description": "Ошибка валидации" }
        }
      }
    },
    "/api/v1/measurements/weight/{id}/": {
      "get": {
        "summary": "Получить запись веса",
        "tags": ["Measurements"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WeightRecord" }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Обновить запись веса",
        "tags": ["Measurements"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WeightRecordWrite" }
            }
          }
        },
        "responses": {
          "200": { "description": "Обновлено" }
        }
      },
      "delete": {
        "summary": "Удалить запись веса",
        "tags": ["Measurements"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "responses": {
          "204": { "description": "Удалено" }
        }
      }
    },
    "/api/v1/measurements/weight/{id}/update_comment/": {
      "patch": {
        "summary": "Обновить комментарий",
        "tags": ["Measurements"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "comment": { "type": "string" }
                },
                "required": ["comment"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Комментарий обновлён" }
        }
      }
    },
    "/api/v1/measurements/weight/{id}/delete_weight/": {
      "delete": {
        "summary": "Удалить запись с подтверждением",
        "tags": ["Measurements"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "responses": {
          "200": { "description": "Запись удалена" }
        }
      }
    },
    "/api/v1/measurements/weight/stats/": {
      "get": {
        "summary": "Статистика веса",
        "tags": ["Measurements"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WeightStats" }
              }
            }
          }
        }
      }
    },
    "/api/v1/measurements/weight/chart-data/": {
      "get": {
        "summary": "Данные для графика веса",
        "tags": ["Measurements"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Массив точек для графика",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/WeightChartPoint" }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT токен для авторизации"
      }
    },
    "parameters": {
      "id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      },
      "ordering": {
        "name": "ordering",
        "in": "query",
        "description": "Сортировка (date, weight, -date, -weight)",
        "schema": { "type": "string" }
      },
      "page": {
        "name": "page",
        "in": "query",
        "description": "Номер страницы",
        "schema": { "type": "integer" }
      }
    },
    "schemas": {
      "WeightRecord": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "readOnly": true },
          "user": { "type": "integer", "readOnly": true, "nullable": true },
          "date": { "type": "string", "format": "date" },
          "weight": { "type": "string", "format": "decimal", "description": "Вес в кг" },
          "comment": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time", "readOnly": true }
        }
      },
      "WeightRecordWrite": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "weight": { "type": "number", "description": "Вес в кг (20-500)" },
          "comment": { "type": "string", "nullable": true }
        },
        "required": ["date", "weight"]
      },
      "PaginatedWeightRecordList": {
        "type": "object",
        "properties": {
          "count": { "type": "integer" },
          "next": { "type": "string", "nullable": true },
          "previous": { "type": "string", "nullable": true },
          "results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/WeightRecord" }
          }
        }
      },
      "WeightStats": {
        "type": "object",
        "properties": {
          "current_weight": { "type": "number" },
          "min_weight": { "type": "number" },
          "max_weight": { "type": "number" },
          "avg_weight": { "type": "number" },
          "total_records": { "type": "integer" },
          "weight_change": { "type": "number" }
        }
      },
      "WeightChartPoint": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "weight": { "type": "number" }
        }
      }
    }
  }
}